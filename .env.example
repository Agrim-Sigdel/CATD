ROBOFLOW_API_KEY="YOUR_ROBOFLOW_API_KEY_HERE"
WORKSPACE_ID="anpr-dswdq"
WORKFLOW_ID="custom-workflow-4"
STAGE_2_ID="licenceplate-w75l3/1"
STAGE_3_ID="anpr-e7qws/4"

# Suppress optional model warnings
CORE_MODEL_SAM_ENABLED=False
CORE_MODEL_SAM3_ENABLED=False
CORE_MODEL_GAZE_ENABLED=False
CORE_MODEL_YOLO_WORLD_ENABLED=False

# Frame sampling for live pipeline (every Nth frame)
FRAME_INTERVAL=10

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=anpr
DETECTIONS_DIR=detections

# Stage 1 confidence threshold — lower catches more vehicles, higher is stricter
STAGE1_CONFIDENCE=0.15

# Video zone sampling — top-N frames per vehicle per zone
# Zone split: first ZONE_EDGE_PCT% | middle | last ZONE_EDGE_PCT%
ZONE_EDGE_PCT=10
ZONE_FRAMES_EDGE=5
ZONE_FRAMES_MID=5
